<Window x:Class="UP01.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:UP01"
        mc:Ignorable="d"
        Title="MainWindow" Height="600" Width="800"
        Topmost="True"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Window.Resources>
        <ImageBrush x:Key="TbBtn_MouseOver" ImageSource="/Resources/Icons/menu.jpg">

        </ImageBrush>
        <Style x:Key="TbBtn_Style" TargetType="{x:Type ToggleButton}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                        <Border x:Name="border" BorderThickness="{TemplateBinding BorderThickness}" Background="{TemplateBinding Background}" SnapsToDevicePixels="True">

                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Background" TargetName="border" Value="{StaticResource TbBtn_MouseOver}"></Setter>
                                <Setter Property="BorderBrush" TargetName="border" Value="{StaticResource TbBtn_MouseOver}"></Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ToolTip" x:Key="tt_Style">
            <Setter Property="Placement" Value="Right"></Setter>
            <Setter Property="Height" Value="50"></Setter>
            <Setter Property="Margin" Value="20, 0,0, 0"></Setter>
            <Setter Property="Background" Value="Gray"></Setter>
            <Setter Property="FontSize" Value="16"></Setter>
            <Setter Property="Foreground" Value="White"></Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid Background="Black">
            <Grid x:Name="NavPanel" HorizontalAlignment="Left" Width="65" Background="Gray">
                <StackPanel x:Name="st_panel">
                    <Grid Height="90">
                        <TextBlock Grid.Row="1" Margin="73, -20, 0, 0" Text="Меню" Foreground="White" Background="Transparent" FontSize="26" HorizontalAlignment="Left" VerticalAlignment="Center">
                            
                        </TextBlock>
                        <ToggleButton  x:Name="TgBtn" VerticalAlignment="Center" Style="{StaticResource TbBtn_Style}" HorizontalAlignment="Left" Margin="5, -20, 0, 0" Height="55" Width="55" BorderThickness="0">
                            <ToggleButton.Background>
                                <ImageBrush ImageSource="/Resources/Icons/menu.jpg"></ImageBrush>
                            </ToggleButton.Background>
                            <ToggleButton.Triggers>
                                <EventTrigger RoutedEvent="ToggleButton.Unchecked">
                                    <BeginStoryboard>
                                        <Storyboard x:Name="HideSidePanel">
                                            <DoubleAnimation
                                                Storyboard.TargetName="NavPanel"
                                                Storyboard.TargetProperty="Width"
                                                BeginTime="0:0:0"
                                                From="230" To="65"
                                                Duration="0:0:0.3"
                                                >
                                                 
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                                <EventTrigger RoutedEvent="ToggleButton.Checked">
                                    <BeginStoryboard>
                                        <Storyboard x:Name="ShowSidePanel">
                                            <DoubleAnimation
                                                Storyboard.TargetName="NavPanel"
                                                Storyboard.TargetProperty="Width"
                                                BeginTime="0:0:0"
                                                From="65" To="230"
                                                Duration="0:0:0.3"
                                                >

                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </ToggleButton.Triggers>
                        </ToggleButton>
                        
                    </Grid>
                    <ListView SelectionChanged="ListV_SelectionChanged" MouseEnter="ListV_MouseEnter" x:Name="ListV" BorderBrush="Transparent" Background="Transparent" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListViewItem x:Name="El1" HorizontalAlignment="Left" Margin="0,0,0,15">
                            <StackPanel Orientation="Horizontal" Width="230">
                                <Image Height="50" Width="50" Source="/Resources/Icons/profile.png"></Image>
                                <TextBlock  Foreground="White" Background="Transparent" FontSize="20" HorizontalAlignment="Left" VerticalAlignment="Center" Text="Профиль" Margin="13, 0, 0, 0"></TextBlock>
                            </StackPanel>
                            <ListViewItem.ToolTip>
                                <ToolTip x:Name="tt1" Style="{StaticResource tt_Style}" Content="Профиль"></ToolTip>
                            </ListViewItem.ToolTip>
                        </ListViewItem>
                        <ListViewItem HorizontalAlignment="Left" Margin="0,0,0,15">
                            <StackPanel Orientation="Horizontal" Width="230">
                                <Image Height="50" Width="50" Source="/Resources/Icons/profile.png"></Image>
                                <TextBlock  Foreground="White" Background="Transparent" FontSize="20" HorizontalAlignment="Left" VerticalAlignment="Center" Text="Профиль" Margin="13, 0, 0, 0"></TextBlock>
                            </StackPanel>
                            <ListViewItem.ToolTip>
                                <ToolTip x:Name="tt2" Style="{StaticResource tt_Style}" Content="Профиль"></ToolTip>
                            </ListViewItem.ToolTip>
                        </ListViewItem>
                        <ListViewItem  HorizontalAlignment="Left" Margin="0,0,0,15">
                            <StackPanel Orientation="Horizontal" Width="230">
                                <Image Height="50" Width="50" Source="/Resources/Icons/profile.png"></Image>
                                <TextBlock  Foreground="White" Background="Transparent" FontSize="20" HorizontalAlignment="Left" VerticalAlignment="Center" Text="Профиль" Margin="13, 0, 0, 0"></TextBlock>
                            </StackPanel>
                            <ListViewItem.ToolTip>
                                <ToolTip x:Name="tt3" Style="{StaticResource tt_Style}" Content="Профиль"></ToolTip>
                            </ListViewItem.ToolTip>
                        </ListViewItem>
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListViewItem">
                                            <Border x:Name="Bd" Height="70" Padding="{TemplateBinding Padding}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Background="{TemplateBinding Background}" SnapsToDevicePixels="True">
                                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}">
                                                    
                                                </ContentPresenter>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" TargetName="Bd" Value="DarkGray"></Setter>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                        
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListView.ItemContainerStyle>
                    </ListView>
                </StackPanel>
            </Grid>
            <Grid Width="740" HorizontalAlignment="Right">
                <Frame x:Name="MainFrame" Source="\Pages\AuthorizationPage.xaml" NavigationUIVisibility="Hidden"></Frame>
            </Grid>
        </Grid>
    </Grid>
</Window>
