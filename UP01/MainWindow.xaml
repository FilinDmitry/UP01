<Window x:Class="UP01.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:UP01"
        mc:Ignorable="d"
        Title="MainWindow" Height="600" Width="800"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <ImageBrush x:Key="TbBtn_MouseOver" ImageSource="/Resources/Icons/menu.jpg">

        </ImageBrush>
        <Style x:Key="TbBtn_Style" TargetType="{x:Type ToggleButton}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                        <Border x:Name="border" BorderThickness="{TemplateBinding BorderThickness}" Background="{TemplateBinding Background}" SnapsToDevicePixels="True">

                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Background" TargetName="border" Value="{StaticResource TbBtn_MouseOver}"></Setter>
                                <Setter Property="BorderBrush" TargetName="border" Value="{StaticResource TbBtn_MouseOver}"></Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
    </Window.Resources>

    <Grid Background="#252525">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="65"></ColumnDefinition>
            <ColumnDefinition Width="*"></ColumnDefinition>
        </Grid.ColumnDefinitions>
        <Grid x:Name="NavPanel" HorizontalAlignment="Left" Width="65" Background="Gray">
            <StackPanel x:Name="st_panel">
                
                <ListView SelectionChanged="ListV_SelectionChanged" MouseEnter="ListV_MouseEnter" x:Name="ListV" BorderBrush="Transparent" Background="Transparent" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListViewItem x:Name="El1" HorizontalAlignment="Left" Margin="0,0,0,15">
                        <StackPanel Orientation="Horizontal" Width="230">
                            <Image Height="50" Width="50" Source="/Resources/Icons/profile.png"></Image>
                            <TextBlock  Foreground="White" Background="Transparent" FontSize="20" HorizontalAlignment="Left" VerticalAlignment="Center" Text="Профиль" Margin="13, 0, 0, 0"></TextBlock>
                        </StackPanel>
                        <ListViewItem.ToolTip>
                            <ToolTip x:Name="tt1" Style="{StaticResource tt_Style}" Content="Профиль"></ToolTip>
                        </ListViewItem.ToolTip>
                    </ListViewItem>
                    <ListViewItem x:Name="El2" HorizontalAlignment="Left" Margin="0,0,0,15">
                        <StackPanel Orientation="Horizontal" Width="230">
                            <Image Height="50" Width="50" Source="/Resources/Icons/profile.png"></Image>
                            <TextBlock  Foreground="White" Background="Transparent" FontSize="20" HorizontalAlignment="Left" VerticalAlignment="Center" Text="Профиль" Margin="13, 0, 0, 0"></TextBlock>
                        </StackPanel>
                        <ListViewItem.ToolTip>
                            <ToolTip x:Name="tt2" Style="{StaticResource tt_Style}" Content="Каталог"></ToolTip>
                        </ListViewItem.ToolTip>
                    </ListViewItem>
                    <ListViewItem x:Name="El3"  HorizontalAlignment="Left" Margin="0,0,0,15">
                        <StackPanel Orientation="Horizontal" Width="230">
                            <Image Height="50" Width="50" Source="/Resources/Icons/profile.png"></Image>
                            <TextBlock  Foreground="White" Background="Transparent" FontSize="20" HorizontalAlignment="Left" VerticalAlignment="Center" Text="Профиль" Margin="13, 0, 0, 0"></TextBlock>
                        </StackPanel>
                        <ListViewItem.ToolTip>
                            <ToolTip x:Name="tt3" Style="{StaticResource tt_Style}" Content="Список чтения"></ToolTip>
                        </ListViewItem.ToolTip>
                    </ListViewItem>
                    <ListViewItem x:Name="El4"  HorizontalAlignment="Left" Margin="0,0,0,15">
                        <StackPanel Orientation="Horizontal" Width="230">
                            <Image Height="50" Width="50" Source="/Resources/Icons/profile.png"></Image>
                            <TextBlock  Foreground="White" Background="Transparent" FontSize="20" HorizontalAlignment="Left" VerticalAlignment="Center" Text="Профиль" Margin="13, 0, 0, 0"></TextBlock>
                        </StackPanel>
                        <ListViewItem.ToolTip>
                            <ToolTip x:Name="tt4" Style="{StaticResource tt_Style}" Content="Страница автора"></ToolTip>
                        </ListViewItem.ToolTip>
                    </ListViewItem>
                    <ListViewItem x:Name="El5" HorizontalAlignment="Left" Margin="0,0,0,15">
                        <StackPanel Orientation="Horizontal" Width="230">
                            <Image Height="50" Width="50" Source="/Resources/Icons/profile.png"></Image>
                            <TextBlock  Foreground="White" Background="Transparent" FontSize="20" HorizontalAlignment="Left" VerticalAlignment="Center" Text="Профиль" Margin="13, 0, 0, 0"></TextBlock>
                        </StackPanel>
                        <ListViewItem.ToolTip>
                            <ToolTip x:Name="tt5" Style="{StaticResource tt_Style}" Content="Страница администратора"></ToolTip>
                        </ListViewItem.ToolTip>
                    </ListViewItem>
                    <ListViewItem x:Name="El6" HorizontalAlignment="Left" Margin="0,0,0,15">
                        <StackPanel Orientation="Horizontal" Width="230">
                            <Image Height="50" Width="50" Source="/Resources/Icons/profile.png"></Image>
                            <TextBlock  Foreground="White" Background="Transparent" FontSize="20" HorizontalAlignment="Left" VerticalAlignment="Center" Text="Профиль" Margin="13, 0, 0, 0"></TextBlock>
                        </StackPanel>
                        <ListViewItem.ToolTip>
                            <ToolTip x:Name="tt6" Style="{StaticResource tt_Style}" Content="Информация о заморозке"></ToolTip>
                        </ListViewItem.ToolTip>
                    </ListViewItem>
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListViewItem">
                                        <Border x:Name="Bd" Height="70" Padding="{TemplateBinding Padding}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Background="{TemplateBinding Background}" SnapsToDevicePixels="True">
                                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}">

                                            </ContentPresenter>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" TargetName="Bd" Value="DarkGray"></Setter>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>

                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListView.ItemContainerStyle>
                </ListView>
            </StackPanel>
        </Grid>
        <Grid Grid.Column="1">
            <Frame x:Name="MainFrame" Source="\Pages\Authorizationpage.xaml" NavigationUIVisibility="Hidden"></Frame>
        </Grid>
    </Grid>
</Window>
