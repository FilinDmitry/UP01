<Window x:Class="UP01.Windows.ReportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:UP01.Windows"
        mc:Ignorable="d"
        Title="Причина жалобы" Height="250" Width="520"
        ResizeMode="NoResize">
    <Grid Background="{StaticResource MainColorBrush}">
        <StackPanel>
            <TextBlock Text="Укажите причину жалобы"></TextBlock>
            <TextBox TextWrapping="NoWrap" FontSize="14" Height="Auto" Margin="0" Width="500"></TextBox>
            <Button Height="30" Width="160">
                <Button.Content>
                    <TextBlock FontSize="16" Margin="0" Text="Отправить"></TextBlock>
                </Button.Content>
            </Button>
        </StackPanel>
    </Grid>
</Window>
