<Window x:Class="UP01.Windows.NewBookWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:UP01.Windows"
        mc:Ignorable="d"
        Title="NewBookWindow" Height="550" Width="800">
    
    <Grid ScrollViewer.HorizontalScrollBarVisibility="Disabled" Background="{StaticResource MainColorBrush}">

        <Grid.RowDefinitions>
            <RowDefinition Height="50"></RowDefinition>
            <RowDefinition Height="80"></RowDefinition>
            <RowDefinition Height="80"></RowDefinition>
            <RowDefinition Height="80"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
            <RowDefinition Height="100"></RowDefinition>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>
        </Grid.ColumnDefinitions>
        <TextBlock Text="Название" Grid.Row="1" HorizontalAlignment="Right" ></TextBlock>
        <TextBox x:Name="TB_Name" Grid.Row="1" Grid.Column="1"  HorizontalAlignment="Stretch"></TextBox>
        <TextBlock Text="Пароль" Grid.Row="2" HorizontalAlignment="Right"></TextBlock>
        <TextBox x:Name="TB_Desc" Grid.Row="2" Grid.Column="1" HorizontalAlignment="Stretch"></TextBox>
        <TextBlock Text="Ссылка на изображение" Grid.Row="3" HorizontalAlignment="Right" ></TextBlock>
        <TextBox x:Name="TB_Image" Grid.Row="3" Grid.Column="1"  HorizontalAlignment="Stretch"></TextBox>
        <TextBlock Text="Текст книги" Grid.Row="4" HorizontalAlignment="Right" ></TextBlock>
        <TextBox ScrollViewer.VerticalScrollBarVisibility="Auto" Height="Auto" x:Name="TB_Content" FontSize="12" TextWrapping="WrapWithOverflow" Grid.Row="4" Grid.Column="1" MinHeight="50"  HorizontalAlignment="Stretch"></TextBox>
        <StackPanel Grid.ColumnSpan="2" Grid.Row="5">
            <Button x:Name="btn" Width="300" Content="Добавить" VerticalAlignment="Top" Click="Button_Click" ></Button>
            
        </StackPanel>
    </Grid>
</Window>
