<Page x:Class="UP01.Pages.BookCatalog"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:UP01.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="550" d:DesignWidth="730"
      Title="BookCatalog">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="80"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
        </Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal">
        <Border>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="30"></ColumnDefinition>
                    <ColumnDefinition Width="*"></ColumnDefinition>
                </Grid.ColumnDefinitions>
                <TextBox MinWidth="400" x:Name="Search" Grid.Column="1"></TextBox>
                <TextBlock Margin="25, 0,0,0" VerticalAlignment="Center" IsHitTestVisible="False" FontSize="20" Foreground="{StaticResource TextColorBrush}" Text="Введите поисковый запрос" Grid.Column="1">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"></Setter>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Text, ElementName=Search}" Value="">
                                    <Setter Property="Visibility" Value="Visible"></Setter>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

            </Grid>
            
        </Border>
            <ComboBox Style="{StaticResource Combo}">
                
            </ComboBox>
            <ComboBox Style="{StaticResource Combo}">
                
            </ComboBox>
        </StackPanel>
        <ListBox ScrollViewer.HorizontalScrollBarVisibility="Disabled" Grid.Row="1" d:ItemsSource="{d:SampleData ItemCount=5}">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        
                    <Border BorderBrush="{StaticResource BorderColorBrush}" BorderThickness="1.5" CornerRadius="5" Padding="3">
                        <StackPanel>
                            <Image Source="/Resources/Icons/profile.png" Height="230" Stretch="Uniform" VerticalAlignment="Bottom"></Image>
                            <TextBlock Text="Name" Margin="5" FontSize="16"></TextBlock>
                                <TextBlock Text="Автор" Margin="5, 0, 5, 0" FontSize="16"></TextBlock>
                                <Button Content="Читать" Margin="2"></Button>
                        </StackPanel>
                    </Border>
                        <Border Margin="3" CornerRadius="3" VerticalAlignment="Top" HorizontalAlignment="Right" Background="{StaticResource SecondColorBrush}">
                            <TextBlock Margin="3" Text="10/10" FontSize="14"/>
                        </Border>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel/>
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
        </ListBox>
    </Grid>
        
</Page>
