<Page x:Class="UP01.Pages.AuthorPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:UP01.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="550" d:DesignWidth="800"
      Title="AuthorPage">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="100"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
        </Grid.RowDefinitions>
        <TextBlock Text="Author" FontSize="30"></TextBlock>
        <Button x:Name="Add" Content="Добавить книгу" Width="300" HorizontalAlignment="Right" Click="Add_Click"></Button>
        <TabControl Background="{StaticResource MainColorBrush}" Grid.Row="1">

            <TabItem Header="Мои книги">
                <ListBox x:Name="lst_books" ScrollViewer.HorizontalScrollBarVisibility="Disabled" Grid.Row="1" d:ItemsSource="{d:SampleData ItemCount=5}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>

                                <Border BorderBrush="{StaticResource BorderColorBrush}" BorderThickness="1.5" CornerRadius="5" Padding="3">
                                    <StackPanel>
                                        <Image Source="{Binding ImagePath}" Height="230" Stretch="Uniform" VerticalAlignment="Bottom"></Image>
                                        <TextBlock Text="{Binding Name}" Margin="5"></TextBlock>
                                        <Button Click="Edit_book_click" Content="Редактировать" Margin="2"></Button>
                                    </StackPanel>
                                </Border>
                                <Border Margin="3" CornerRadius="3" VerticalAlignment="Top" HorizontalAlignment="Right" Background="{StaticResource SecondColorBrush}">
                                    <TextBlock Margin="3" Text="{Binding Avg}" FontSize="14"/>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                </ListBox>
            </TabItem>
            <TabItem Header="Замороженные книги">
                <ListBox x:Name="lst_freeze" ScrollViewer.HorizontalScrollBarVisibility="Disabled" Grid.Row="1" d:ItemsSource="{d:SampleData ItemCount=5}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>

                                <Border BorderBrush="{StaticResource BorderColorBrush}" BorderThickness="1.5" CornerRadius="5" Padding="3">
                                    <StackPanel MaxWidth="340">
                                        <Image Source="{Binding ImagePath}" Height="230" Stretch="Uniform" VerticalAlignment="Bottom"></Image>
                                        <TextBlock Text="{Binding Name}" Margin="5" TextWrapping="Wrap"></TextBlock>
                                        <TextBlock Margin="5" Text="{Binding book.ReasonToFreeze}" FontSize="14" TextWrapping="Wrap"></TextBlock>
                                        <Button Content="Оспорить заморозку" Click="Unfreeze_Click" Margin="2"></Button>
                                    </StackPanel>
                                </Border>
                                <Border Margin="3" CornerRadius="3" VerticalAlignment="Top" HorizontalAlignment="Right" Background="{StaticResource SecondColorBrush}">
                                    <TextBlock Margin="3" Text="{Binding Avg}" FontSize="14"/>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                </ListBox>
            </TabItem>
        </TabControl>
    </Grid>
</Page>
