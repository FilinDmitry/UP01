<Page x:Class="UP01.Pages.RegestrationPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:UP01.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="550" d:DesignWidth="800"
      Title="RegestrationPage">

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="50"></RowDefinition>
            <RowDefinition Height="80"></RowDefinition>
            <RowDefinition Height="80"></RowDefinition>
            <RowDefinition Height="80"></RowDefinition>
            <RowDefinition Height="80"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>
        </Grid.ColumnDefinitions>
        <TextBlock Text="Логин" Grid.Row="1" HorizontalAlignment="Right" ></TextBlock>
        <TextBox x:Name="TB_Login" Width="400" Grid.Row="1" Grid.Column="1"  HorizontalAlignment="Left"></TextBox>
        <TextBlock Text="Пароль" Grid.Row="2" HorizontalAlignment="Right"></TextBlock>
        <PasswordBox x:Name="TB_Password" Width="400" Grid.Row="2" Grid.Column="1" HorizontalAlignment="Left"></PasswordBox>
        <TextBlock Text="Почта" Grid.Row="3" HorizontalAlignment="Right" ></TextBlock>
        <TextBox x:Name="TB_Email" Width="400" Grid.Row="3" Grid.Column="1"  HorizontalAlignment="Left"></TextBox>
        <TextBlock Text="Отображаемое имя" Grid.Row="4" HorizontalAlignment="Right" ></TextBlock>
        <TextBox x:Name="TB_Name" Width="400" Grid.Row="4" Grid.Column="1"  HorizontalAlignment="Left"></TextBox>
        <StackPanel Grid.ColumnSpan="2" Grid.Row="5">
        <Button Width="300" Content="Зарегестрироваться" VerticalAlignment="Top" Click="RegButtonClick" ></Button>
        <TextBlock MouseLeftButtonDown="To_RegPage" TextAlignment="Center" Text="Уже есть аккант? Войти " FontStyle="Italic" TextDecorations="Baseline" Margin="0"></TextBlock>
        </StackPanel>
    </Grid>
</Page>
