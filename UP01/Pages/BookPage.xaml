<Page x:Class="UP01.Pages.BookPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:UP01.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="550" d:DesignWidth="730"
      Title="BookPage">
    
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"></RowDefinition>
            <RowDefinition Height="300"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
        </Grid.RowDefinitions>
        <TextBlock Text="{Binding Name}" FontSize="24"></TextBlock>
        <Button Grid.Row="0" HorizontalAlignment="Right" Width="50" Height="50">
            <Image Width="50" Height="50" Source="/Resources/Icons/menu.jpg" ></Image>
            <Button.Resources>
                <ContextMenu x:Key="cm">

                    <MenuItem Header="Жалоба на книгу" Click="Menu_Book_Report">

                    </MenuItem>
                    <MenuItem Header="Жалоба на автора"  Click="Menu_Author_Report"/>
                    <MenuItem Visibility="Collapsed" Header="Заморозить"></MenuItem>
                    <MenuItem Visibility="Collapsed" Header="Разморозить"></MenuItem>
                </ContextMenu>
            </Button.Resources>
            <Button.Style>
                
                <Style TargetType="{x:Type Button}">
                    <Style.Triggers>
                        <EventTrigger RoutedEvent="Click">
                            <EventTrigger.Actions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <BooleanAnimationUsingKeyFrames Storyboard.TargetProperty="ContextMenu.IsOpen">
                                            <DiscreteBooleanKeyFrame KeyTime="0:0:0" Value="True"/>
                                        </BooleanAnimationUsingKeyFrames>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger.Actions>
                        </EventTrigger>
                    </Style.Triggers>

                    <Setter Property="ContextMenu" Value="{StaticResource cm}"/>

                </Style>
            </Button.Style>
            
        </Button>
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"></ColumnDefinition>
                <ColumnDefinition Width="2*"></ColumnDefinition>
                <ColumnDefinition Width="1*"></ColumnDefinition>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"></RowDefinition>
                <RowDefinition Height="50"></RowDefinition>
            </Grid.RowDefinitions>
            <Image VerticalAlignment="Top" Source="{Binding ImagePath}" Grid.Row="0" Grid.RowSpan="2" Stretch="Uniform"></Image>
            <StackPanel Grid.Column="1" Grid.Row="0" VerticalAlignment="Top">
                <TextBlock TextWrapping="Wrap" Text="{Binding Path=Author, StringFormat=Автор: {0}}"></TextBlock>
                <TextBlock TextWrapping="Wrap" Text="{Binding Path=Genres, StringFormat=Жанры: {0}}"></TextBlock>
                <TextBlock TextWrapping="Wrap" FontSize="16" Text="{Binding Description}" ></TextBlock>
            </StackPanel>
            
            <StackPanel Grid.Row="0" Grid.Column="2">
                <TextBlock Text="{Binding Rating}" HorizontalAlignment="Right"></TextBlock>
                <Button Margin="0, 15, 15, 15" Content="Читать" Click="ReadBook_Click"></Button>
                <Button Margin="0, 15, 15, 15" Content="Создать отзыв" Click="CreateReview_Click"></Button>
            </StackPanel>
        </Grid>
        <ListBox x:Name="LB_Reviews" HorizontalContentAlignment="Stretch" Grid.Row="2" d:ItemsSource="{d:SampleData ItemCount=5}">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <TextBlock Text="{Binding Date, StringFormat=D}" VerticalAlignment="Bottom" Margin="3" FontSize="12" HorizontalAlignment="Right" Foreground="{StaticResource SecondTextColorBrush}"></TextBlock>
                        <Border BorderBrush="{StaticResource BorderColorBrush}" BorderThickness="1.5" CornerRadius="5" Padding="3">
                            <StackPanel>
                                <TextBlock Margin="5" Text="{Binding Users.Name}" FontSize="24"></TextBlock>
                                <TextBlock Margin="5" Text="{Binding Message}" TextWrapping="Wrap" FontSize="18"></TextBlock>
                            </StackPanel>
                        </Border>
                        <StackPanel Margin="0, 5, 10, 0" VerticalAlignment="Top" HorizontalAlignment="Right" Orientation="Horizontal">
                            <TextBlock  Text="{Binding Path=Rating, StringFormat=Оценка: {0}/10}"  Margin="0, 0, 10, 0"/>
                            <Button BorderThickness="0" Background="Transparent" Margin="2" Padding="0"  Click="Review_Report_Click" Tag="{Binding}" Grid.Row="0" HorizontalAlignment="Right" Width="30" Height="30">
                                <Image Width="30" Height="30" Source="/Resources/Icons/menu.jpg"></Image>

                                <Button.ToolTip>
                                    <ToolTip Content="Пожаловаться" Placement="Left" Style="{StaticResource tt_Style}" Height="30">

                                    </ToolTip>
                                </Button.ToolTip>

                            </Button>
                            <Button Visibility="{Binding IsUserAdmin, RelativeSource={RelativeSource AncestorType=Page}}" x:Name="Freezer" Click="Freezer_Click" BorderThickness="0" Background="Transparent" Margin="2" Padding="0"  Tag="{Binding}" Grid.Row="0" HorizontalAlignment="Right" Width="30" Height="30">
                                <Image Width="30" Height="30" Source="/Resources/Icons/menu.jpg"></Image>
                                
                                <Button.ToolTip>
                                    <ToolTip Content="Заморозить" Placement="Left" Style="{StaticResource tt_Style}" Height="30">

                                    </ToolTip>
                                </Button.ToolTip>

                            </Button>
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
            
        </ListBox>
    </Grid>
</Page>
