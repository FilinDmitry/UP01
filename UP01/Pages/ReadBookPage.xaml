<Page x:Class="UP01.Pages.ReadBookPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:UP01.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ReadBookPage">

    <Grid Background="{StaticResource MainColorBrush}">
        
        <TextBox Background="Transparent" BorderThickness="0" ScrollViewer.VerticalScrollBarVisibility="Auto" Height="Auto" x:Name="TB_Content" Margin="0, 50, 20, 0" FontSize="12" TextWrapping="WrapWithOverflow" Grid.Row="4" Grid.Column="1" MinHeight="50"  HorizontalAlignment="Stretch" VerticalAlignment="Stretch"></TextBox>
        <Button Content="Назад" Height="50" Width="100" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0" Click="Button_Click"></Button>
     </Grid>
</Page>
