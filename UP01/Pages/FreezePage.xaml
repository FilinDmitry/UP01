<Page x:Class="UP01.Pages.FreezePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:UP01.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="550" d:DesignWidth="730"
      Title="FreezePage">

    <Grid>
        <StackPanel>
            <TextBlock Text="Информация о блокировке (Login)" TextAlignment="Center" TextWrapping="Wrap"></TextBlock>

            <TextBlock TextAlignment="Justify" Text="Ваш аккаунт был заморожен, вы не можете оставлять комментарии, писать обзоры или создавать новые книги (для авторов), но вы по прежнему можете читать книги и добавлять их в свои списки." TextWrapping="Wrap"></TextBlock>
        <TextBlock TextAlignment="Justify" Text="Reason to ban"></TextBlock>
        <TextBlock Text="Если вы не согласны с заморозкой акканта вы можете её оспорить"></TextBlock>
        <Button Content="Оспорить заморозку"></Button>
        </StackPanel>
    </Grid>
</Page>
