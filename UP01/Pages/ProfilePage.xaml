<Page x:Class="UP01.Pages.ProfilePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:UP01.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="550" d:DesignWidth="730"
      Title="ProfilePage">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"></ColumnDefinition>
            <ColumnDefinition Width="*"></ColumnDefinition>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="300"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
        </Grid.RowDefinitions>
        <StackPanel>
            <TextBlock Text="{Binding Login}"></TextBlock>
            <TextBlock Text="{Binding Name}"></TextBlock>
            <TextBlock Text="{Binding Email}"></TextBlock>
            <TextBlock Text="{Binding Roles.Name}"></TextBlock>
            
        </StackPanel>
        <StackPanel Grid.Column="1">
            <Button Click="Became_author_click" Content="Стать автором"></Button>
            <StackPanel x:Name="SP_Freeze" Visibility="Collapsed">
                <TextBlock Text="Ваш аккаунт был заморожен" TextWrapping="Wrap"></TextBlock>
                <Button Click="Button_Click" Content="Подробнее"></Button>
            </StackPanel>
        </StackPanel>
        <ListBox ScrollViewer.HorizontalScrollBarVisibility="Disabled" x:Name="LB_comments" Grid.ColumnSpan="2" HorizontalContentAlignment="Stretch"  Grid.Row="2" d:ItemsSource="{d:SampleData ItemCount=5}">
            
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid MinHeight="100">
                        <TextBlock Text="{Binding Date, StringFormat=D}" VerticalAlignment="Bottom" Margin="3" FontSize="12" HorizontalAlignment="Right" Foreground="{StaticResource SecondTextColorBrush}"></TextBlock>
                        <Border BorderBrush="{StaticResource BorderColorBrush}" BorderThickness="1.5" CornerRadius="5" Padding="3">
                            <StackPanel>
                                <TextBlock Margin="5" Text="{Binding Users.Name}" FontSize="24"></TextBlock>
                                <TextBlock Margin="5" Text="{Binding Message}" TextWrapping="Wrap" FontSize="18"></TextBlock>
                            </StackPanel>
                        </Border>

                        <TextBlock Margin="3" Text="{Binding Path=Rating, StringFormat=Оценка: {0}/10}" VerticalAlignment="Top" HorizontalAlignment="Right"/>

                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>

        </ListBox>
    </Grid>
</Page>
