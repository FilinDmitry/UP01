<Page x:Class="UP01.Pages.ProfilePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:UP01.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="550" d:DesignWidth="800"
      Title="ProfilePage">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"></ColumnDefinition>
            <ColumnDefinition Width="*"></ColumnDefinition>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="300"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
        </Grid.RowDefinitions>
        <StackPanel>
            <TextBlock Text="Логин"></TextBlock>
            <TextBlock Text="Отображаемое имя"></TextBlock>
            <TextBlock Text="Электронная почта"></TextBlock>
            <TextBlock Text="Роль"></TextBlock>
            
        </StackPanel>
        <StackPanel Grid.Column="1">
            <Button Content="Стать автором"></Button>
            <StackPanel Visibility="Collapsed">
                <TextBlock Text="Ваш аккаунт был заморожен по причине: " TextWrapping="Wrap"></TextBlock>
                <Button Content="Оспорить заморозку"></Button>
            </StackPanel>
        </StackPanel>
        <ListBox Grid.Row="1" Grid.ColumnSpan="2"></ListBox>
    </Grid>
</Page>
