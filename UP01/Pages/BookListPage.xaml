<Page x:Class="UP01.Pages.BookListPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:UP01.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="550" d:DesignWidth="730"
      Title="BookListPage"
      Loaded="Page_Loaded">


    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="80"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
        </Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal">
            <Border>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="0"></ColumnDefinition>
                        <ColumnDefinition Width="*"></ColumnDefinition>
                    </Grid.ColumnDefinitions>
                    <TextBox TextChanged="Search_TextChanged" MinWidth="400" x:Name="Search" Grid.Column="1"></TextBox>
                    <TextBlock Margin="25, 0,0,0" VerticalAlignment="Center" IsHitTestVisible="False" FontSize="20" Foreground="{StaticResource TextColorBrush}" Text="Введите поисковый запрос" Grid.Column="1">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"></Setter>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Text, ElementName=Search}" Value="">
                                        <Setter Property="Visibility" Value="Visible"></Setter>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                </Grid>

            </Border>
            <Grid>
                <ComboBox SelectionChanged="Genre_SelectionChanged" x:Name="Genre" Style="{StaticResource Combo}" FontSize="14">
                </ComboBox>
                <TextBlock Margin="20,0,0,0" VerticalAlignment="Center" IsHitTestVisible="False" FontSize="16" Foreground="{StaticResource TextColorBrush}" Text="Жанр" Grid.Column="1">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"></Setter>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedIndex, ElementName=Genre}" Value="-1">
                                    <Setter Property="Visibility" Value="Visible"></Setter>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>
            <Grid>
                <ComboBox SelectionChanged="Genre_SelectionChanged" Width="140" x:Name="Sort" Style="{StaticResource Combo}" FontSize="14">
                    <ComboBoxItem>
                        <TextBlock Text="По рейтингу"></TextBlock>
                    </ComboBoxItem>
                    <ComboBoxItem>
                        <TextBlock Text="По имени"></TextBlock>
                    </ComboBoxItem>
                </ComboBox>
                <TextBlock Margin="20,0,0,0" VerticalAlignment="Center" IsHitTestVisible="False" FontSize="16" Foreground="{StaticResource TextColorBrush}" Text="Сортировка" Grid.Column="1">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"></Setter>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedIndex, ElementName=Sort}" Value="-1">
                                    <Setter Property="Visibility" Value="Visible"></Setter>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>
        </StackPanel>
        <TabControl SelectionChanged="TabControl_SelectionChanged" x:Name="ListTabControl"  Background="{StaticResource MainColorBrush}" Grid.Row="1">
            <TabControl.ContentTemplate>
                <DataTemplate>
                    <ListBox MouseDoubleClick="LB_ReadingList_MouseDoubleClick" x:Name="LB_ReadingList" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled" Grid.Row="1" d:ItemsSource="{d:SampleData ItemCount=5}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>

                                    <Border BorderBrush="{StaticResource BorderColorBrush}" BorderThickness="1.5" CornerRadius="5" Padding="3">
                                        <StackPanel>
                                            <Image Source="{Binding ImagePath}" Height="230" Stretch="Uniform" VerticalAlignment="Bottom"></Image>
                                            <TextBlock Text="{Binding Name}" Margin="5" FontSize="16"></TextBlock>
                                            <TextBlock Text="{Binding Author}" Margin="5, 0, 5, 0" FontSize="16"></TextBlock>
                                            <ComboBox SelectionChanged="ComboBox_SelectionChanged"  ItemsSource="{Binding DataContext.lists, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=ListBoxItem}, Mode=OneTime}" SelectedItem="{Binding Status}" Style="{StaticResource Combo}" HorizontalAlignment="Stretch" Width="Auto"></ComboBox>
                                        </StackPanel>
                                    </Border>
                                    <Border Margin="3" CornerRadius="3" VerticalAlignment="Top" HorizontalAlignment="Right" Background="{StaticResource SecondColorBrush}">
                                        <TextBlock Margin="3" Text="{Binding Avg}" FontSize="14"/>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                    </ListBox>
                </DataTemplate>
            </TabControl.ContentTemplate>
            <TabItem Tag="Все">
                <TabItem.Header>
                    <TextBlock Margin="0" Text="Все" HorizontalAlignment="Center"></TextBlock>
                </TabItem.Header>
            </TabItem>
            <TabItem Header="Прочитано" Tag="Прочитано">

            </TabItem>
            <TabItem Header="Читаю" Tag="Читаю">

            </TabItem>
            <TabItem Header="В планах" Tag="В планах">

            </TabItem>
            <TabItem Header="Заброшено" Tag="Заброшено">

            </TabItem>
        </TabControl>
        
    </Grid>
</Page>
